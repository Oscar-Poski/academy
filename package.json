    "eslint-config-prettier": "9.1.0",
    "jest": "29.7.0",
    "prettier": "3.4.2",
    "supertest": "7.0.0",
    "ts-jest": "29.2.5",
    "tsx": "4.19.2",
    "turbo": "2.3.3",
