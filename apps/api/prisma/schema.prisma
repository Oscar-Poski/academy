generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SectionVersionStatus {
  draft
  published
  archived
}

enum LessonBlockType {
  markdown
  callout
  code
  quiz
  checklist
}

enum ProgressStatus {
  not_started
  in_progress
  completed
}

enum QuestionType {
  mcq
  short_answer
}

enum UnlockScopeType {
  path
  module
  section
}

enum UnlockRuleType {
  prereq_sections
  quiz_pass
  credits
  min_level
}

enum CreditEventType {
  grant
  spend
  adjust
}

enum XpEventType {
  section_complete
  quiz_pass
  streak
  manual
}

enum XpSourceType {
  section
  quiz_attempt
  system
  manual
}

enum UserRole {
  user
  admin
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         UserRole @default(user)
  passwordHash String?  @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sectionProgress UserSectionProgress[]
  quizAttempts    QuizAttempt[]
  unlocks         UserUnlock[]
  creditEvents    CreditEvent[]
  userCredit      UserCredit?
  xpEvents        XpEvent[]
  userLevel       UserLevel?
  refreshTokens   AuthRefreshToken[]

  @@map("users")
}

model AuthRefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([userId, revokedAt])
  @@map("auth_refresh_tokens")
}

model Path {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  status      String   @default("draft")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  modules Module[]

  @@map("paths")
}

model Module {
  id          String   @id @default(cuid())
  pathId      String   @map("path_id")
  slug        String   @unique
  title       String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  status      String   @default("draft")
  creditsCost Int      @default(0) @map("credits_cost")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  path     Path      @relation(fields: [pathId], references: [id], onDelete: Cascade)
  sections Section[]

  @@index([pathId])
  @@map("modules")
}

model Section {
  id        String   @id @default(cuid())
  moduleId  String   @map("module_id")
  slug      String   @unique
  title     String
  sortOrder Int      @default(0) @map("sort_order")
  hasQuiz   Boolean  @default(false) @map("has_quiz")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  module          Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  sectionVersions SectionVersion[]
  sectionProgress UserSectionProgress[]
  quizAttempts    QuizAttempt[]

  @@index([moduleId])
  @@map("sections")
}

model SectionVersion {
  id            String               @id @default(cuid())
  sectionId     String               @map("section_id")
  versionNumber Int                  @map("version_number")
  status        SectionVersionStatus @default(draft)
  changeLog     String?              @map("change_log")
  publishedAt   DateTime?            @map("published_at")
  createdBy     String?              @map("created_by")
  createdAt     DateTime             @default(now()) @map("created_at")

  section         Section              @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  lessonBlocks    LessonBlock[]
  questions       Question[]
  quizAttempts    QuizAttempt[]
  sectionProgress UserSectionProgress[]

  @@unique([sectionId, versionNumber])
  @@index([sectionId, status])
  @@map("section_versions")
}

model LessonBlock {
  id               String          @id @default(cuid())
  sectionVersionId String          @map("section_version_id")
  blockOrder       Int             @map("block_order")
  blockType        LessonBlockType @map("block_type")
  contentJson      Json            @map("content_json")
  estimatedSeconds Int?            @map("estimated_seconds")

  sectionVersion SectionVersion @relation(fields: [sectionVersionId], references: [id], onDelete: Cascade)
  questions      Question[]

  @@unique([sectionVersionId, blockOrder])
  @@index([sectionVersionId])
  @@map("lesson_blocks")
}

model Question {
  id               String       @id @default(cuid())
  sectionVersionId String       @map("section_version_id")
  blockId          String?      @map("block_id")
  type             QuestionType
  prompt           String
  optionsJson      Json?        @map("options_json")
  answerKeyJson    Json         @map("answer_key_json")
  explanation      String?
  points           Int          @default(1)
  sortOrder        Int          @default(0) @map("sort_order")
  createdAt        DateTime     @default(now()) @map("created_at")

  sectionVersion SectionVersion    @relation(fields: [sectionVersionId], references: [id], onDelete: Cascade)
  block          LessonBlock?      @relation(fields: [blockId], references: [id], onDelete: SetNull)
  attemptAnswers QuizAttemptAnswer[]

  @@index([sectionVersionId, sortOrder])
  @@index([blockId])
  @@map("questions")
}

model QuizAttempt {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  sectionId         String   @map("section_id")
  sectionVersionId  String   @map("section_version_id")
  attemptNo         Int      @map("attempt_no")
  submittedAt       DateTime @default(now()) @map("submitted_at")
  score             Int
  maxScore          Int      @map("max_score")
  passed            Boolean
  gradingDetailsJson Json    @map("grading_details_json")

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  section        Section           @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sectionVersion SectionVersion    @relation(fields: [sectionVersionId], references: [id], onDelete: Cascade)
  answers        QuizAttemptAnswer[]

  @@unique([userId, sectionId, attemptNo])
  @@index([userId, sectionId, submittedAt])
  @@index([sectionVersionId])
  @@map("quiz_attempts")
}

model QuizAttemptAnswer {
  id           String  @id @default(cuid())
  attemptId    String  @map("attempt_id")
  questionId   String  @map("question_id")
  answerJson   Json    @map("answer_json")
  isCorrect    Boolean @map("is_correct")
  awardedPoints Int    @default(0) @map("awarded_points")

  attempt  QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
  @@map("quiz_attempt_answers")
}

model UserSectionProgress {
  id              String         @id @default(cuid())
  userId          String         @map("user_id")
  sectionId       String         @map("section_id")
  sectionVersionId String        @map("section_version_id")
  status          ProgressStatus @default(not_started)
  startedAt       DateTime?      @map("started_at")
  lastSeenAt      DateTime?      @map("last_seen_at")
  completedAt     DateTime?      @map("completed_at")
  completionPct   Int            @default(0) @map("completion_pct")
  lastBlockOrder  Int?           @map("last_block_order")
  timeSpentSeconds Int           @default(0) @map("time_spent_seconds")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  section        Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sectionVersion SectionVersion @relation(fields: [sectionVersionId], references: [id], onDelete: Cascade)

  @@unique([userId, sectionId])
  @@index([userId, status, lastSeenAt])
  @@index([sectionId])
  @@index([sectionVersionId])
  @@map("user_section_progress")
}

model AnalyticsEvent {
  id               String   @id @default(cuid())
  idempotencyKey   String?  @unique @map("idempotency_key")
  userId           String?  @map("user_id")
  eventName        String   @map("event_name")
  pathId           String?  @map("path_id")
  moduleId         String?  @map("module_id")
  sectionId        String?  @map("section_id")
  sectionVersionId String?  @map("section_version_id")
  payloadJson      Json     @map("payload_json")
  occurredAt       DateTime @map("occurred_at")
  receivedAt       DateTime @default(now()) @map("received_at")

  @@index([eventName, occurredAt])
  @@index([userId, occurredAt])
  @@index([sectionId, occurredAt])
  @@index([moduleId, occurredAt])
  @@map("analytics_events")
}

model UnlockRule {
  id             String          @id @default(cuid())
  scopeType      UnlockScopeType @map("scope_type")
  scopeId        String          @map("scope_id")
  ruleType       UnlockRuleType  @map("rule_type")
  ruleConfigJson Json            @map("rule_config_json")
  isActive       Boolean         @default(true) @map("is_active")
  priority       Int             @default(0)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@index([scopeType, scopeId, isActive])
  @@index([ruleType])
  @@index([priority])
  @@map("unlock_rules")
}

model UserUnlock {
  id         String          @id @default(cuid())
  userId     String          @map("user_id")
  scopeType  UnlockScopeType @map("scope_type")
  scopeId    String          @map("scope_id")
  reason     String?
  unlockedAt DateTime        @default(now()) @map("unlocked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, scopeType, scopeId])
  @@index([scopeType, scopeId])
  @@index([userId, unlockedAt])
  @@map("user_unlocks")
}

model CreditEvent {
  id             String          @id @default(cuid())
  userId         String          @map("user_id")
  eventType      CreditEventType @map("event_type")
  amount         Int
  reason         String?
  idempotencyKey String          @unique @map("idempotency_key")
  createdAt      DateTime        @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@map("credit_events")
}

model UserCredit {
  userId    String   @id @map("user_id")
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_credits")
}

model XpEvent {
  id             String       @id @default(cuid())
  userId         String       @map("user_id")
  eventType      XpEventType  @map("event_type")
  sourceType     XpSourceType @map("source_type")
  sourceId       String       @map("source_id")
  xpDelta        Int          @map("xp_delta")
  idempotencyKey String       @unique @map("idempotency_key")
  createdAt      DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@map("xp_events")
}

model UserLevel {
  userId    String   @id @map("user_id")
  totalXp   Int      @default(0) @map("total_xp")
  level     Int      @default(1)
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_levels")
}
